async function updateInvLine(invId,lineId,field,val){
  await sb.from('invoice_lines').update({[field]:val}).eq('id',lineId);
  const inv=C.invoices.find(x=>x.id===invId);if(!inv)return;
  const line=inv.invoice_lines?.find(x=>x.id===lineId);if(line)line[field]=val;
  const total=inv.invoice_lines.reduce((a,l)=>a+(Number(l.sell_price)*Number(l.qty)),0);
  inv.total=total;await sb.from('invoices').update({total}).eq('id',invId);
  const c=C.customers.find(x=>x.id===inv.customer_id)||{};const j=C.jobs.find(x=>x.id===inv.job_id)||{};
  renderInvBody(inv,c,j,c.service_plan==='maintenance');
}
async function removeInvLine(invId,lineId){
  await sb.from('invoice_lines').delete().eq('id',lineId);
  const inv=C.invoices.find(x=>x.id===invId);if(inv)inv.invoice_lines=inv.invoice_lines.filter(x=>x.id!==lineId);
  const total=inv?.invoice_lines.reduce((a,l)=>a+(Number(l.sell_price)*Number(l.qty)),0)||0;
  if(inv){inv.total=total;await sb.from('invoices').update({total}).eq('id',invId);}
  const c=C.customers.find(x=>x.id===inv?.customer_id)||{};const j=C.jobs.find(x=>x.id===inv?.job_id)||{};
  if(inv)renderInvBody(inv,c,j,c.service_plan==='maintenance');
}
async function addInvLine(invId,type){
  const{data:line}=await sb.from('invoice_lines').insert({invoice_id:invId,description:type==='labor'?'Labor — ':'',line_type:type,qty:1,unit_cost:0,sell_price:0}).select().single();
  const inv=C.invoices.find(x=>x.id===invId);if(inv&&line)inv.invoice_lines.push(line);
  const c=C.customers.find(x=>x.id===inv?.customer_id)||{};const j=C.jobs.find(x=>x.id===inv?.job_id)||{};
