function editMaterial(id){
  const m=C.materials.find(x=>x.id===id);if(!m)return;
  document.getElementById('mat-modal-title').textContent='Edit Material';
  document.getElementById('mat-edit-id').value=m.id;
  document.getElementById('mat-name').value=m.name||'';
  document.getElementById('mat-cat').value=m.category||'Other';
  document.getElementById('mat-unit').value=m.unit||'each';
  document.getElementById('mat-cost').value=m.unit_cost||'';
  document.getElementById('mat-supplier').value=m.supplier||'';
  document.getElementById('mat-sku').value=m.sku||'';
  openModal('material');
}
async function saveMaterial(){
  const btn=document.getElementById('mat-save-btn');
  const eid=document.getElementById('mat-edit-id').value;
  const name=document.getElementById('mat-name').value.trim();
  if(!name){showToast('Name required','error');return;}
  btn.disabled=true;btn.textContent='Saving…';
  const payload={name,category:document.getElementById('mat-cat').value,unit:document.getElementById('mat-unit').value,unit_cost:parseFloat(document.getElementById('mat-cost').value)||0,supplier:document.getElementById('mat-supplier').value,sku:document.getElementById('mat-sku').value,updated_at:new Date().toISOString()};
  if(eid){
    await sb.from('materials').update(payload).eq('id',parseInt(eid));
    const idx=C.materials.findIndex(x=>x.id===parseInt(eid));if(idx>=0)C.materials[idx]={...C.materials[idx],...payload};
    showToast('Material updated','success');
  } else {
    const{data}=await sb.from('materials').insert(payload).select().single();
    if(data)C.materials.push(data);C.materials.sort((a,b)=>a.name.localeCompare(b.name));
    showToast('Material added','success');
  }
  btn.disabled=false;btn.textContent='Save Material';
  closeModal('material');renderMaterials();
}

