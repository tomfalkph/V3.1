async function saveCustomer(){
  const btn=document.getElementById('cust-save-btn');
  const acctType=document.querySelector('input[name="cust-acct-type"]:checked').value;
  const phone=document.getElementById('cust-phone').value.trim();
  if(!phone){showToast('Phone required','error');return;}
  let first='',last='',business='',contactName='',contactTitle='';
  if(acctType==='residential'){first=document.getElementById('cust-first').value.trim();last=document.getElementById('cust-last').value.trim();if(!first||!last){showToast('Name required','error');return;}}
  else{business=document.getElementById('cust-business').value.trim();if(!business){showToast('Business name required','error');return;}contactName=document.getElementById('cust-contact-name').value.trim();contactTitle=document.getElementById('cust-contact-title').value.trim();}
  const propRows=document.querySelectorAll('#cust-properties .property-row');
  const properties=[];
  propRows.forEach((row,i)=>{const addr=row.querySelector('.prop-addr-input').value.trim();const notes=row.querySelector('.prop-note-input').value.trim();if(addr)properties.push({addr,notes,sort_order:i});});
  if(!properties.length){showToast('At least one service address required','error');return;}
  btn.disabled=true;btn.textContent='Saving…';
  const{data:newCust,error}=await sb.from('customers').insert({acct_type:acctType,first,last,business,contact_name:contactName,contact_title:contactTitle,phone,email:document.getElementById('cust-email').value.trim(),billing_addr:document.getElementById('cust-billing-addr').value.trim(),service_plan:document.getElementById('cust-type').value,source:document.getElementById('cust-source').value,notes:document.getElementById('cust-notes').value.trim(),created_by:C.currentUser?.id}).select().single();
  if(error){showToast('Error saving','error');btn.disabled=false;btn.textContent='Save Customer';return;}
  const{data:props}=await sb.from('properties').insert(properties.map(p=>({customer_id:newCust.id,...p}))).select();
  newCust.properties=props||[];
  C.customers.unshift(newCust);
  btn.disabled=false;btn.textContent='Save Customer';
  closeModal('customer');showToast(`Customer added — ${custDisplayName(newCust)}`,'success');
  renderCustomers();renderDashboard();
}

