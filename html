// ═══════════════════════════════════════════
// HELPERS
// ═══════════════════════════════════════════
function custDisplayName(c){return c?.acct_type==='commercial'?c.business:`${c?.first||''} ${c?.last||''}`.trim();}
function custPrimaryAddr(c){return c?.properties?.[0]?.addr||'';}
function statusPill(s){const m={unscheduled:'Unscheduled',scheduled:'Scheduled',inprogress:'In Progress',pending_review:'Pending Review',complete:'Complete',invoiced:'Invoiced',paid:'Paid',draft:'Draft',flagged:'Flagged'};return `<span class="pill pill-${s}">${m[s]||s}</span>`;}
function fmtTime(t){if(!t)return'';const[h,m]=t.split(':');const hr=parseInt(h);return`${hr>12?hr-12:hr||12}:${m} ${hr>=12?'PM':'AM'}`;}
function fmtDate(d){if(!d)return'—';const dt=new Date(d+'T00:00:00');return dt.toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'});}
function fmtDateTime(ts){if(!ts)return'—';const d=new Date(ts);return d.toLocaleDateString('en-US',{month:'short',day:'numeric'})+' '+d.toLocaleTimeString('en-US',{hour:'numeric',minute:'2-digit'});}
function calcMargin(cost,isMaint){if(cost<=25)return 0.50;if(cost<=150)return 0.45;if(cost<=1999)return 0.40;return isMaint?0.35:0.40;}
function sellPrice(cost,isMaint){const m=calcMargin(cost,isMaint);return parseFloat((cost/(1-m)).toFixed(2));}
function getSetting(key,def){return parseFloat(C.settings[key])||def;}
function updateBadges(){
  document.getElementById('jobs-badge').textContent=C.jobs.filter(j=>j.status==='unscheduled').length;
  document.getElementById('review-badge').textContent=C.jobs.filter(j=>j.status==='pending_review').length;
}

