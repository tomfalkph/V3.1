function renderCalcMats(){document.getElementById('calc-mats').innerHTML=calcMats.map((m,i)=>`<div style="display:grid;grid-template-columns:1fr 90px 60px 80px 28px;gap:6px;align-items:center;margin-bottom:6px"><input type="text" placeholder="Description" value="${m.desc||''}" oninput="calcMats[${i}].desc=this.value" style="font-size:12px;padding:5px 8px"><input type="number" placeholder="Cost $" value="${m.cost||''}" step="0.01" min="0" oninput="calcMats[${i}].cost=+this.value;calcUpdate()" style="font-size:12px;padding:5px 8px"><div id="mat-tag-${i}" style="font-size:10px;color:var(--gray-500);font-family:'IBM Plex Mono',monospace;text-align:center"></div><div id="mat-sell-${i}" style="font-size:12px;font-family:'IBM Plex Mono',monospace;text-align:right;color:var(--green)"></div><button class="btn btn-ghost btn-sm" onclick="calcMats.splice(${i},1);renderCalcMats();calcUpdate()" style="color:var(--gray-400)">✕</button></div>`).join('');}
function calcUpdate(){
  const isMaint=document.querySelector('input[name="calc-cust-type"]:checked')?.value==='maintenance';
  const rateMap={service:getSetting('service_call_rate',202),continuous:getSetting('continuous_rate',182),install:getSetting('install_rate',164)};
  let lt=0,lb=[];
  calcLabors.forEach(l=>{const hrs=parseFloat(l.hours)||0;const rate=rateMap[l.type]||202;const sub=hrs*rate;lt+=sub;if(hrs>0)lb.push(`${hrs}h ${l.type} @ $${rate} = $${sub.toFixed(2)}`);});
  let mt=0;
  calcMats.forEach((m,i)=>{const cost=parseFloat(m.cost)||0;const t=document.getElementById('mat-tag-'+i);const s=document.getElementById('mat-sell-'+i);if(cost<=0){if(t)t.textContent='';if(s)s.textContent='';return;}const margin=calcMargin(cost,isMaint);const sell=cost/(1-margin);mt+=sell;if(t)t.textContent=`${Math.round(margin*100)}%`;if(s)s.textContent=`$${sell.toFixed(2)}`;});
  document.getElementById('calc-result').innerHTML=`${lb.map(b=>`<div class="calc-result-row"><span class="r-label">${b}</span></div>`).join('')}<div class="calc-result-row"><span class="r-label">Labor Total</span><span class="r-value">$${lt.toFixed(2)}</span></div><div class="calc-result-row"><span class="r-label">Materials</span><span class="r-value">$${mt.toFixed(2)}</span></div><div class="calc-result-row total"><span class="r-label">Total</span><span class="r-value">$${(lt+mt).toFixed(2)}</span></div>`;
}

