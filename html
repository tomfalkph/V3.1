      </div>
    </div>

    <div style="display:flex;gap:16px;padding:12px;background:var(--gray-50);border-radius:6px;margin-bottom:16px;font-size:12px;flex-wrap:wrap">
      <span><strong style="color:var(--red)">$${totalCost.toFixed(2)}</strong> cost</span>
      <span><strong>$${subtotal.toFixed(2)}</strong> revenue</span>
      <span><strong class="${grossProfit>=0?'profit-positive':'profit-negative'}">$${grossProfit.toFixed(2)}</strong> gross profit</span>
      <span><strong class="${parseFloat(margin)>=30?'profit-positive':'profit-negative'}">${margin}%</strong> margin</span>
    </div>

    <div style="display:grid;grid-template-columns:1fr 80px 110px 110px 30px;gap:8px;align-items:center;padding:8px 0;border-bottom:2px solid var(--gray-200);font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:var(--gray-500);font-weight:600"><div>Description</div><div>Qty</div><div>Unit Price</div><div>Total</div><div></div></div>
    ${lines.map(l=>`<div style="display:grid;grid-template-columns:1fr 80px 110px 110px 30px;gap:8px;align-items:center;padding:8px 0;border-bottom:1px solid var(--gray-100)">
      <div><input type="text" value="${l.description||''}" onchange="updateInvLine(${inv.id},${l.id},'description',this.value)" style="font-size:13px">
        ${l.line_type==='material'?`<div style="font-size:10px;color:var(--gray-500);font-family:'IBM Plex Mono',monospace;margin-top:3px">Cost $${Number(l.unit_cost).toFixed(2)} · ${Math.round(calcMargin(Number(l.unit_cost),isMaint)*100)}% margin</div>`:''}</div>
      <input type="number" value="${l.qty}" min="0.25" step="0.25" onchange="updateInvLine(${inv.id},${l.id},'qty',+this.value)" style="font-size:13px">
      <input type="number" value="${Number(l.sell_price).toFixed(2)}" min="0" step="0.01" onchange="updateInvLine(${inv.id},${l.id},'sell_price',+this.value)" style="font-size:13px">
      <div style="font-family:'IBM Plex Mono',monospace;font-weight:500">$${(Number(l.sell_price)*Number(l.qty)).toFixed(2)}</div>
      <button class="btn btn-ghost btn-sm" onclick="removeInvLine(${inv.id},${l.id})" style="color:var(--gray-400)">✕</button>
    </div>`).join('')}
    <div style="display:flex;gap:8px;margin-top:12px">
      <button class="btn btn-secondary btn-sm" onclick="addInvLine(${inv.id},'labor')">+ Labor</button>
      <button class="btn btn-secondary btn-sm" onclick="addInvLineMat(${inv.id})">+ Material</button>
    </div>
    <div style="margin-top:20px">
      <div style="display:flex;justify-content:flex-end;gap:40px;padding:10px 0;font-size:16px;font-weight:700;border-top:2px solid var(--gray-200)"><span>Total Due</span><span style="font-family:'IBM Plex Mono',monospace;color:var(--red)">$${subtotal.toFixed(2)}</span></div>
    </div>
