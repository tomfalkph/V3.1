}
async function addInvLineMat(invId){
  const inv=C.invoices.find(x=>x.id===invId);const c=C.customers.find(x=>x.id===inv?.customer_id)||{};const isMaint=c.service_plan==='maintenance';
  const name=prompt('Material name (or search pricebook):');if(!name)return;
  const match=C.materials.find(m=>m.name.toLowerCase().includes(name.toLowerCase()));
  const cost=match?Number(match.unit_cost):parseFloat(prompt('Unit cost ($):')||'0');
  if(isNaN(cost))return;
  const sell=sellPrice(cost,isMaint);
  const{data:line}=await sb.from('invoice_lines').insert({invoice_id:invId,description:match?match.name:name,line_type:'material',qty:1,unit_cost:cost,sell_price:sell}).select().single();
  if(inv&&line)inv.invoice_lines.push(line);
  const total=inv.invoice_lines.reduce((a,l)=>a+(Number(l.sell_price)*Number(l.qty)),0);
  inv.total=total;await sb.from('invoices').update({total}).eq('id',invId);
  const j=C.jobs.find(x=>x.id===inv?.job_id)||{};
  renderInvBody(inv,c,j,isMaint);
}
async function updateInvNotes(invId,val){await sb.from('invoices').update({notes:val}).eq('id',invId);const inv=C.invoices.find(x=>x.id===invId);if(inv)inv.notes=val;}
async function markInvStatus(invId,status){
  await sb.from('invoices').update({status}).eq('id',invId);
  const inv=C.invoices.find(x=>x.id===invId);if(inv)inv.status=status;
  if(status==='invoiced'){const j=C.jobs.find(x=>x.id===inv?.job_id);if(j){j.status='invoiced';await sb.from('jobs').update({status:'invoiced'}).eq('id',j.id);}}
  showToast(`Invoice #${String(invId).padStart(4,'0')} marked ${status}`,'success');
  const c=C.customers.find(x=>x.id===inv?.customer_id)||{};const j=C.jobs.find(x=>x.id===inv?.job_id)||{};
  renderInvBody(inv,c,j,c.service_plan==='maintenance');updateBadges();renderDashboard();
}

