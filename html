let techGpsCoords={lat:null,lng:null};
function requestGPS(btnId,statusId){
  if(!navigator.geolocation){
    document.getElementById(statusId).className='gps-status gps-err';
    document.getElementById(statusId).textContent='GPS not available on this device';
    return;
  }
  navigator.geolocation.getCurrentPosition(pos=>{
    techGpsCoords={lat:pos.coords.latitude,lng:pos.coords.longitude};
    const el=document.getElementById(statusId);
    if(el){el.className='gps-status gps-ok';el.textContent=`📍 Location confirmed (${techGpsCoords.lat.toFixed(4)}, ${techGpsCoords.lng.toFixed(4)})`;}
    const btn=document.getElementById(btnId);
    if(btn){
      btn.disabled=false;
      // Re-check minimum time for clock-out
      if(btnId==='clockout-btn'&&techActiveEntry){
        const minMs=getSetting('min_clockout_minutes',15)*60*1000;
        const elapsed=Date.now()-new Date(techActiveEntry.clock_in).getTime();
        if(elapsed<minMs){btn.disabled=true;btn.textContent=`Need ${Math.ceil((minMs-elapsed)/60000)} more min`;}
      }
    }
  },err=>{
    const el=document.getElementById(statusId);
    if(el){el.className='gps-status gps-err';el.textContent='GPS denied — location required to continue';}
  },{enableHighAccuracy:true,timeout:15000});
}

function startTechTimer(clockInTs,minMs){
  clearInterval(techTimerInterval);
  const start=new Date(clockInTs).getTime();
  techTimerInterval=setInterval(()=>{
    const el=document.getElementById('tech-timer');if(!el){clearInterval(techTimerInterval);return;}
    const elapsed=Date.now()-start;
    const h=Math.floor(elapsed/3600000);const m=Math.floor((elapsed%3600000)/60000);const s=Math.floor((elapsed%60000)/1000);
    el.textContent=`${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
    el.className=`tech-timer ${elapsed>=minMs?'ready':'warning'}`;
    // Unlock clock out after min time
    if(elapsed>=minMs){
      const btn=document.getElementById('clockout-btn');
      const msg=document.getElementById('min-timer-msg');
      if(btn&&techGpsCoords.lat){btn.disabled=false;btn.textContent='Clock Out';}
      if(msg)msg.style.display='none';
    }
  },1000);
}

