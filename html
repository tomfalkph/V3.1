function openJobDetail(id){
  const j=C.jobs.find(x=>x.id===id);if(!j)return;
  const c=C.customers.find(x=>x.id===j.customer_id)||{};
  const entries=C.timeEntries.filter(t=>t.job_id===id);
  const totalMins=entries.filter(t=>t.clock_out).reduce((a,t)=>a+(t.duration_minutes||0),0);
  const totalHrs=(totalMins/60);
  const laborCost=totalHrs*getSetting('labor_cost_per_hour',120);
  const inv=C.invoices.find(i=>i.job_id===id);
  const steps=['unscheduled','scheduled','inprogress','pending_review','complete','invoiced'];
  const ci=steps.indexOf(j.status);
  const labels={unscheduled:'Unscheduled',scheduled:'Scheduled',inprogress:'In Progress',pending_review:'Pending Review',complete:'Complete',invoiced:'Invoiced'};

  document.getElementById('jd-title').textContent=`Job #${j.id} — ${custDisplayName(c)}`;
  document.getElementById('jd-body').innerHTML=`
    <div class="pipeline">${steps.map((s,i)=>{
      const cls=i<ci?'done':i===ci?'current':'';
      const canAdv=i===ci+1&&s!=='invoiced'&&C.currentProfile?.role==='owner';
      return`<div class="pipe-step ${cls} ${canAdv?'clickable-step':''}" ${canAdv?`onclick="advanceJob(${id},'${s}')"`:''}>${labels[s]||s}</div>`;
    }).join('')}</div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px">
      <div>
        <div class="cd-section-title">Job Info</div>
        <table style="width:100%;font-size:13px;border-collapse:collapse">
          <tr><td style="padding:5px 0;color:var(--gray-500);width:110px">Type</td><td>${j.job_type||'—'}</td></tr>
          <tr><td style="padding:5px 0;color:var(--gray-500)">Tech</td><td>${j.tech||'<strong style="color:var(--red)">Unassigned</strong>'}</td></tr>
          <tr><td style="padding:5px 0;color:var(--gray-500)">Scheduled</td><td>${j.scheduled_date?fmtDate(j.scheduled_date)+' '+fmtTime(j.scheduled_time):'Not scheduled'}</td></tr>
          <tr><td style="padding:5px 0;color:var(--gray-500)">Priority</td><td style="text-transform:capitalize">${j.priority}</td></tr>
        </table>
        ${j.notes?`<div style="margin-top:10px;font-size:13px;color:var(--gray-600);padding:10px;background:var(--yellow-bg);border-radius:5px;border-left:3px solid var(--yellow)">${j.notes}</div>`:''}
      </div>
      <div>
        <div class="cd-section-title">Customer</div>
        <div style="font-size:15px;font-weight:600">${custDisplayName(c)}</div>
        <div style="font-size:13px;color:var(--gray-600);margin-top:3px">${c.phone||''}</div>
        <div style="font-size:13px;color:var(--gray-600)">${custPrimaryAddr(c)}</div>
        <div style="margin-top:6px">${c.service_plan==='maintenance'?'<span class="tag tag-maint">Maintenance Plan</span>':'<span class="tag tag-standard">Standard</span>'}</div>
      </div>
    </div>

    <div class="cd-section-title">Time Log</div>
    ${entries.length?`<table class="tbl" style="margin-bottom:16px"><thead><tr><th>Tech</th><th>Clock In</th><th>Clock Out</th><th>Duration</th><th>Location</th><th>Flag</th></tr></thead><tbody>
    ${entries.map(e=>`<tr class="${e.flagged?'flag-row':''}">
      <td>${e.tech_name||'—'}</td>
      <td>${fmtDateTime(e.clock_in)}</td>
      <td>${e.clock_out?fmtDateTime(e.clock_out):'<span style="color:var(--yellow)">Active</span>'}</td>
      <td>${e.duration_minutes?Math.floor(e.duration_minutes/60)+'h '+(e.duration_minutes%60)+'m':'—'}</td>
      <td>${e.clock_in_lat?`<a href="https://www.google.com/maps?q=${e.clock_in_lat},${e.clock_in_lng}" target="_blank" style="color:var(--blue);font-size:11px">📍 View</a>`:'—'}</td>
      <td>${e.flagged?`<span class="pill pill-unscheduled" title="${e.flag_reason}">⚠ ${e.flag_reason}</span>`:'—'}</td>
    </tr>`).join('')}</tbody></table>
    <div style="display:flex;gap:24px;padding:10px 12px;background:var(--gray-50);border-radius:6px;margin-bottom:16px;font-size:13px">
      <span><strong>${totalHrs.toFixed(1)}h</strong> <span style="color:var(--gray-500)">total time</span></span>
      <span><strong style="color:var(--red)">$${laborCost.toFixed(2)}</strong> <span style="color:var(--gray-500)">labor cost @ $${getSetting('labor_cost_per_hour',120)}/hr</span></span>
      ${inv?`<span><strong style="color:var(--green)">$${Number(inv.total).toFixed(2)}</strong> <span style="color:var(--gray-500)">invoiced</span></span>
      <span><strong class="${(inv.total-laborCost)>=0?'profit-positive':'profit-negative'}">$${(inv.total-laborCost).toFixed(2)}</strong> <span style="color:var(--gray-500)">gross profit</span></span>`:''}
    </div>`:`<div style="color:var(--gray-400);font-size:13px;margin-bottom:16px">No time entries yet</div>`}

    ${entries.some(e=>e.completion_note)?`<div class="cd-section-title">Completion Notes</div>
    ${entries.filter(e=>e.completion_note).map(e=>`<div style="padding:10px 12px;background:var(--gray-50);border-radius:6px;font-size:13px;margin-bottom:8px;border-left:3px solid var(--blue)"><strong>${e.tech_name}</strong>: ${e.completion_note}</div>`).join('')}`:''}
  `;

  const footer=document.getElementById('jd-footer');
  let btns=`<button class="btn btn-secondary" onclick="closeModal('jobdetail')">Close</button>`;
  if(j.status==='pending_review') btns+=`<button class="btn btn-secondary" onclick="approveReview(${id});closeModal('jobdetail')">Approve → Complete</button>`;
  if(j.status==='complete') btns+=`<button class="btn btn-primary" onclick="closeModal('jobdetail');buildInvoice(${id})">Build Invoice →</button>`;
  if(['unscheduled','scheduled'].includes(j.status)) btns+=`<button class="btn btn-secondary" onclick="closeModal('jobdetail');openModal('job',${id})">Edit</button>`;
  footer.innerHTML=btns;
  openModal('jobdetail');
}

async function advanceJob(id,nextStatus){
  await sb.from('jobs').update({status:nextStatus}).eq('id',id);
  const j=C.jobs.find(x=>x.id===id);if(j)j.status=nextStatus;
  showToast(`Job #${id} → ${nextStatus}`,'success');
  openJobDetail(id);renderDashboard();updateBadges();
}

async function saveJob(){
  const btn=document.getElementById('job-save-btn');
  const eid=document.getElementById('job-edit-id').value;
  const custId=parseInt(document.getElementById('job-customer').value);
  if(!custId){showToast('Select a customer','error');return;}
  btn.disabled=true;btn.textContent='Saving…';
  const tech=document.getElementById('job-tech').value;
  const date=document.getElementById('job-date').value;
  const payload={customer_id:custId,job_type:document.getElementById('job-type').value,tech,priority:document.getElementById('job-priority').value,scheduled_date:date||null,scheduled_time:document.getElementById('job-time').value||null,notes:document.getElementById('job-notes').value,status:tech&&date?'scheduled':'unscheduled'};
  if(eid){
    const{error}=await sb.from('jobs').update(payload).eq('id',parseInt(eid));
    if(!error){const idx=C.jobs.findIndex(x=>x.id===parseInt(eid));if(idx>=0)C.jobs[idx]={...C.jobs[idx],...payload};}
    showToast(error?'Error':'Job updated',error?'error':'success');
  } else {
    const{data,error}=await sb.from('jobs').insert({...payload,created_by:C.currentUser?.id}).select().single();
    if(!error&&data)C.jobs.unshift(data);
    showToast(error?'Error':'Job created',error?'error':'success');
  }
  btn.disabled=false;btn.textContent='Save Job';
  closeModal('job');renderDashboard();
  if(document.getElementById('view-jobs').classList.contains('active'))renderJobs();
}

