function changeWeek(d){schedWeekOffset+=d;renderSchedule();}
function renderSchedule(){
  const today=new Date();const start=new Date(today);start.setDate(today.getDate()-today.getDay()+1+schedWeekOffset*7);
  const days=Array.from({length:5},(_,i)=>{const d=new Date(start);d.setDate(start.getDate()+i);return d;});
  document.getElementById('schedule-week-label').textContent=`Week of ${days[0].toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'})}`;
  const dayStrs=days.map(d=>d.toISOString().slice(0,10));
  const times=['8 AM','9 AM','10 AM','11 AM','12 PM','1 PM','2 PM','3 PM','4 PM','5 PM'];
  document.getElementById('schedule-wrap').innerHTML=`<table class="tbl" style="background:white;border-radius:8px;border:1px solid var(--gray-200);overflow:hidden"><thead><tr><th style="width:60px"></th>${days.map(d=>`<th style="text-align:center;font-size:10px;letter-spacing:1px;text-transform:uppercase;color:var(--gray-500);font-weight:600;padding:10px;background:var(--gray-50);border-bottom:1px solid var(--gray-200)">${d.toLocaleDateString('en-US',{weekday:'short',month:'short',day:'numeric'})}</th>`).join('')}</tr></thead><tbody>${times.map((t,ti)=>`<tr><td style="padding:16px 8px;font-size:11px;color:var(--gray-500);border-right:1px solid var(--gray-200);text-align:right;font-family:'IBM Plex Mono',monospace;vertical-align:top">${t}</td>${dayStrs.map(ds=>{const hr=ti+8;const jobs=C.jobs.filter(j=>j.scheduled_date===ds&&j.scheduled_time&&parseInt(j.scheduled_time.split(':')[0])===hr&&['scheduled','inprogress'].includes(j.status));return`<td style="padding:6px;border-right:1px solid var(--gray-100);border-bottom:1px solid var(--gray-100);min-height:56px;vertical-align:top">${jobs.map(j=>{const c=C.customers.find(x=>x.id===j.customer_id)||{};const techCls=j.tech==='Jim'?'jim':j.tech==='Jeff'?'jeff':'apprentice';return`<div class="sch-block sch-block-${techCls}" onclick="openJobDetail(${j.id})" style="border-radius:4px;padding:5px 8px;font-size:11px;font-weight:500;margin-bottom:3px;cursor:pointer;background:${j.tech==='Jim'?'#fdecea':j.tech==='Jeff'?'var(--gray-800)':'var(--blue-bg)'};color:${j.tech==='Jim'?'var(--red-dark)':j.tech==='Jeff'?'var(--gray-300)':'var(--blue)'}">${custDisplayName(c).split(' ').pop()} · ${(j.job_type||'').split('—')[0].trim()}</div>`;}).join('')}</td>`;}).join('')}</tr>`).join('')}</tbody></table>`;
}

