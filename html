function exportData(){
  const blob=new Blob([JSON.stringify({exported:new Date().toISOString(),customers:C.customers,jobs:C.jobs,invoices:C.invoices,materials:C.materials,timeEntries:C.timeEntries},null,2)],{type:'application/json'});
  const a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download=`TomFalk_Backup_${new Date().toISOString().slice(0,10)}.json`;a.click();
  showToast('Backup downloaded','success');
}

// GLOBAL SEARCH
document.getElementById('global-search').addEventListener('input',function(){
  const q=this.value.toLowerCase().trim();if(!q)return;
  const match=C.customers.find(c=>`${custDisplayName(c)} ${c.phone} ${(c.properties||[]).map(p=>p.addr).join(' ')}`.toLowerCase().includes(q));
  if(match){showView('customers');selectedCustomerId=match.id;renderCustomers();}
});

// TOAST
function showToast(msg,type=''){const t=document.getElementById('toast');const el=document.createElement('div');el.className=`toast-item${type?' '+type:''}`;el.textContent=msg;t.appendChild(el);setTimeout(()=>el.classList.add('show'),10);setTimeout(()=>{el.classList.remove('show');setTimeout(()=>el.remove(),300)},3500);}
</script>
