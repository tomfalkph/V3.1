  const activeEntry=C.timeEntries.find(t=>t.user_id===C.currentUser.id&&!t.clock_out);
  techActiveEntry=activeEntry||null;

  if(!activeJob&&!activeEntry){
    document.getElementById('tech-content').innerHTML=`
      <div class="no-jobs"><div class="no-jobs-icon">✅</div>
      <div style="font-size:18px;font-weight:600;color:var(--white);margin-bottom:8px">No jobs assigned today</div>
