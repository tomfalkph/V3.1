function addCalcLabor(){calcLabors.push({type:'continuous',hours:1});renderCalcLabors();calcUpdate();}
function renderCalcLabors(){
  const rates={service:`Service Call ($${getSetting('service_call_rate',202)}/hr)`,continuous:`Continuous ($${getSetting('continuous_rate',182)}/hr)`,install:`Installation ($${getSetting('install_rate',164)}/hr)`};
