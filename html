  document.getElementById('dash-today').innerHTML=todayJobs.length?todayJobs.map(j=>{const c=C.customers.find(x=>x.id===j.customer_id)||{};return`<tr class="clickable" onclick="openJobDetail(${j.id})"><td>${custDisplayName(c)}</td><td>${j.tech||'Unassigned'}</td><td>${statusPill(j.status)}</td></tr>`;}).join(''):'<tr><td colspan="3" style="text-align:center;color:var(--gray-400);padding:16px">No jobs today</td></tr>';
  document.getElementById('dash-review').innerHTML=pendingReview.length?pendingReview.map(j=>{
