function openModal(name,jobId,preCustomerId){
  if(name==='job'){
    const sel=document.getElementById('job-customer');
    sel.innerHTML='<option value="">— Select customer —</option>'+C.customers.map(c=>`<option value="${c.id}">${custDisplayName(c)}</option>`).join('');
    if(preCustomerId)sel.value=preCustomerId;
    if(jobId){const j=C.jobs.find(x=>x.id===jobId);if(j){document.getElementById('job-modal-title').textContent='Edit Job';document.getElementById('job-edit-id').value=j.id;document.getElementById('job-customer').value=j.customer_id;document.getElementById('job-type').value=j.job_type||'';document.getElementById('job-tech').value=j.tech||'';document.getElementById('job-priority').value=j.priority||'normal';document.getElementById('job-date').value=j.scheduled_date||'';document.getElementById('job-time').value=j.scheduled_time||'';document.getElementById('job-notes').value=j.notes||'';}}
    else{document.getElementById('job-modal-title').textContent='New Job';document.getElementById('job-edit-id').value='';['job-tech','job-date','job-time','job-notes'].forEach(id=>document.getElementById(id).value='');document.getElementById('job-priority').value='normal';}
  }
  if(name==='customer'){
    document.getElementById('cust-dupe-warn').style.display='none';
    document.querySelectorAll('input[name="cust-acct-type"]')[0].checked=true;toggleCustType();
    ['cust-first','cust-last','cust-business','cust-contact-name','cust-contact-title','cust-phone','cust-email','cust-billing-addr','cust-notes'].forEach(id=>document.getElementById(id).value='');
    document.getElementById('cust-type').value='standard';
    document.getElementById('cust-properties').innerHTML=`<div class="property-row"><div style="flex:1;position:relative"><input type="text" class="prop-addr-input" placeholder="Service address" autocomplete="off" oninput="handleAddrInput(this)"><div class="addr-suggestions"></div></div><input type="text" class="prop-note-input" placeholder="Unit #, access notes" style="width:190px"></div>`;
  }
  if(name==='material'){
    if(!document.getElementById('mat-edit-id').value){document.getElementById('mat-modal-title').textContent='Add Material';['mat-name','mat-cost','mat-supplier','mat-sku'].forEach(id=>document.getElementById(id).value='');document.getElementById('mat-unit').value='each';}
  }
  if(name==='calc'){calcLabors=[{type:'service',hours:1}];calcMats=[{cost:'',desc:''}];renderCalcLabors();renderCalcMats();calcUpdate();}
  document.getElementById('modal-'+name).classList.add('open');
}
function closeModal(name){document.getElementById('modal-'+name).classList.remove('open');if(name==='material')document.getElementById('mat-edit-id').value='';}
document.querySelectorAll('.modal-overlay').forEach(o=>o.addEventListener('click',e=>{if(e.target===o)o.classList.remove('open');}));

