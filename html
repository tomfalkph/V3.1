async function buildInvoice(jobId){
  const j=C.jobs.find(x=>x.id===jobId);if(!j)return;
  const c=C.customers.find(x=>x.id===j.customer_id)||{};
  const isMaint=c.service_plan==='maintenance';
  // Calculate actual hours from time entries
  const entries=C.timeEntries.filter(t=>t.job_id===jobId&&t.clock_out);
  const totalMins=entries.reduce((a,t)=>a+(t.duration_minutes||0),0);
  const totalHrs=parseFloat((totalMins/60).toFixed(2))||1;
  const rate=getSetting('service_call_rate',202);
  const laborTotal=parseFloat((totalHrs*rate).toFixed(2));
  const{data:inv,error}=await sb.from('invoices').insert({job_id:jobId,customer_id:j.customer_id,status:'draft',total:laborTotal}).select().single();
  if(error){showToast('Error creating invoice','error');return;}
  const{data:line}=await sb.from('invoice_lines').insert({invoice_id:inv.id,description:`${j.job_type} — ${j.tech||'Tech'} (${totalHrs}h)`,line_type:'labor',qty:1,unit_cost:laborTotal,sell_price:laborTotal,sort_order:0}).select().single();
  inv.invoice_lines=[line];
  C.invoices.unshift(inv);
  j.invoice_id=inv.id;
  await sb.from('jobs').update({invoice_id:inv.id}).eq('id',jobId);
  currentInvId=inv.id;
  openInvoiceDetail(inv.id);
}

function openInvoiceDetail(invId){
  const inv=C.invoices.find(x=>x.id===invId);if(!inv)return;
  currentInvId=invId;
  const c=C.customers.find(x=>x.id===inv.customer_id)||{};
  const j=C.jobs.find(x=>x.id===inv.job_id)||{};
  const isMaint=c.service_plan==='maintenance';
  document.getElementById('inv-modal-title').textContent=`Invoice #${String(invId).padStart(4,'0')} — ${custDisplayName(c)}`;
  renderInvBody(inv,c,j,isMaint);
  openModal('invoice');
}

