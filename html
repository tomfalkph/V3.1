async function clockIn(jobId){
  const btn=document.getElementById('clockin-btn');btn.disabled=true;btn.textContent='Clocking in…';
  const techName=C.currentProfile?.name||C.currentUser?.email?.split('@')[0]||'Tech';
  const{data:entry,error}=await sb.from('time_entries').insert({
    job_id:jobId,user_id:C.currentUser.id,tech_name:techName,
    clock_in:new Date().toISOString(),
    clock_in_lat:techGpsCoords.lat,clock_in_lng:techGpsCoords.lng
  }).select().single();
  if(error){showToast('Error clocking in','error');btn.disabled=false;btn.textContent='Clock In';return;}
  // Update job status
  await sb.from('jobs').update({status:'inprogress'}).eq('id',jobId);
  const j=C.jobs.find(x=>x.id===jobId);if(j)j.status='inprogress';
  C.timeEntries.unshift(entry);
  techActiveEntry=entry;
  techMats=[];
  showToast('Clocked in','success');
  renderTechClockOut(entry,C.jobs.find(x=>x.id===jobId));
}

async function clockOut(entryId,jobId){
  const note=document.getElementById('tech-note')?.value.trim();
  if(!note){showToast('Completion note required','error');return;}
  const btn=document.getElementById('clockout-btn');btn.disabled=true;btn.textContent='Clocking out…';
  const entry=C.timeEntries.find(x=>x.id===entryId);
  const clockOut=new Date().toISOString();
  const durationMins=Math.round((Date.now()-new Date(entry.clock_in).getTime())/60000);
  const minRequired=getSetting('min_clockout_minutes',15);
  const flagged=durationMins<minRequired;
  const flagReason=flagged?`Under ${minRequired} min (${durationMins} min recorded)`:'';

  await sb.from('time_entries').update({clock_out:clockOut,clock_out_lat:techGpsCoords.lat,clock_out_lng:techGpsCoords.lng,duration_minutes:durationMins,completion_note:note,flagged,flag_reason:flagReason}).eq('id',entryId);

  // Save materials (no pricing shown to tech)
  if(techMats.filter(m=>m.name).length){
    const matPayloads=techMats.filter(m=>m.name).map(m=>{
      const match=C.materials.find(x=>x.name.toLowerCase()===m.name.toLowerCase());
      return{job_id:jobId,material_id:match?.id||null,raw_description:m.name,quantity:m.qty,unit_cost:match?Number(match.unit_cost):0,sell_price:match?sellPrice(Number(match.unit_cost),false):0,submitted_by:C.currentUser.id};
    });
    await sb.from('job_materials').insert(matPayloads);
  }

  // Upload photo if taken
  const photoInput=document.getElementById('job-card-photo');
  if(photoInput?.files[0]){
    const file=photoInput.files[0];
    const path=`${jobId}/${Date.now()}_jobcard.jpg`;
    await sb.storage.from('job-photos').upload(path,file);
    await sb.from('job_photos').insert({job_id:jobId,storage_path:path,photo_type:'job_card',uploaded_by:C.currentUser.id});
  }

  // Advance job to pending_review
  await sb.from('jobs').update({status:'pending_review'}).eq('id',jobId);
  const j=C.jobs.find(x=>x.id===jobId);if(j)j.status='pending_review';
  const e=C.timeEntries.find(x=>x.id===entryId);
  if(e){e.clock_out=clockOut;e.duration_minutes=durationMins;e.completion_note=note;e.flagged=flagged;}
  techActiveEntry=null;clearInterval(techTimerInterval);
  showToast(flagged?'Clocked out — entry flagged for review':'Clocked out successfully',flagged?'error':'success');
  renderTechView();
}

